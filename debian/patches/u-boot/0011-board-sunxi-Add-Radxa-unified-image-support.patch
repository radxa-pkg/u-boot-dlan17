From 47e274a0474056a993be7ca28a529426f28244bd Mon Sep 17 00:00:00 2001
From: Feng Zhang <feng@radxa.com>
Date: Mon, 2 Mar 2026 03:43:11 +0000
Subject: [PATCH 2/3] board: sunxi: Add Radxa unified image support

Signed-off-by: Feng Zhang <feng@radxa.com>
---
 board/sunxi/Kconfig       |  8 ++++
 board/sunxi/Makefile      |  1 +
 board/sunxi/board.c       |  9 +++++
 board/sunxi/cubie_board.c | 78 +++++++++++++++++++++++++++++++++++++++
 board/sunxi/cubie_board.h | 23 ++++++++++++
 5 files changed, 119 insertions(+)
 create mode 100644 board/sunxi/cubie_board.c
 create mode 100644 board/sunxi/cubie_board.h

diff --git a/src/board/sunxi/Kconfig b/src/board/sunxi/Kconfig
index 084a8b0c6ca..91793f8ae88 100644
--- a/src/board/sunxi/Kconfig
+++ b/src/board/sunxi/Kconfig
@@ -22,3 +22,11 @@ config SPL_IMAGE_TYPE
 	string
 	default "sunxi_egon" if SPL_IMAGE_TYPE_SUNXI_EGON
 	default "sunxi_toc0" if SPL_IMAGE_TYPE_SUNXI_TOC0
+
+config RADXA_UNIFIED_IMAGE
+	bool "Enable Radxa unified image support"
+	depends on ADC && SUNXI_GPADC && DM
+	help
+		Enable support for Radxa unified image. This feature allows the same
+		image to run on multiple Radxa boards by reading the hardware ID
+		to automatically detect and select the appropriate board configuration.
\ No newline at end of file
diff --git a/src/board/sunxi/Makefile b/src/board/sunxi/Makefile
index d96b7897b6c..18117fae3bf 100644
--- a/src/board/sunxi/Makefile
+++ b/src/board/sunxi/Makefile
@@ -12,3 +12,4 @@ obj-$(CONFIG_MACH_SUN4I)	+= dram_sun4i_auto.o
 obj-$(CONFIG_MACH_SUN5I)	+= dram_sun5i_auto.o
 obj-$(CONFIG_MACH_SUN7I)	+= dram_sun5i_auto.o
 obj-$(CONFIG_$(PHASE_)CHIP_DIP_SCAN)	+= chip.o
+obj-$(CONFIG_RADXA_UNIFIED_IMAGE) += cubie_board.o
diff --git a/src/board/sunxi/board.c b/src/board/sunxi/board.c
index 2929bc17f08..8d50a5c91c0 100644
--- a/src/board/sunxi/board.c
+++ b/src/board/sunxi/board.c
@@ -54,6 +54,11 @@
 
 DECLARE_GLOBAL_DATA_PTR;
 
+#ifdef CONFIG_RADXA_UNIFIED_IMAGE
+extern void radxa_set_board_type(void);
+extern void radxa_set_compat_fdt(void);
+#endif
+
 void i2c_init_board(void)
 {
 #ifdef CONFIG_I2C0_ENABLE
@@ -852,6 +857,10 @@ int board_late_init(void)
 	usb_ether_init();
 #endif
 
+#ifdef CONFIG_RADXA_UNIFIED_IMAGE
+	radxa_set_board_type();
+	radxa_set_compat_fdt();
+#endif
 	return 0;
 }
 
diff --git a/src/board/sunxi/cubie_board.c b/src/board/sunxi/cubie_board.c
new file mode 100644
index 00000000000..61bb55af97e
--- /dev/null
+++ b/src/board/sunxi/cubie_board.c
@@ -0,0 +1,78 @@
+#include <env.h>
+#include <asm-generic/gpio.h>
+#include <sunxi_gpadc.h>
+#include <dm/device.h>
+#include "cubie_board.h"
+
+unsigned int board_index = 0;
+static const struct hw_info_def hw_info[] = {
+	{
+		.compatible = "allwinner,sun60i-a733",
+		.fdtfile = "allwinner/sun60i-a733-cubie-a7z.dtb",
+		.pcie_power_gpio = "PD20",
+		.pcie_wake_gpio = "PD21",
+		.pcie_reset_gpio = "PD22",
+		.hw_id_level = 1,
+		.hw_id_lower_bound = 1750,
+		.hw_id_upper_bound = 1850, //1800mv +/- 50mv
+	},
+	{
+		.compatible = "allwinner,sun60i-a733",
+		.fdtfile = "allwinner/sun60i-a733-cubie-a7a.dtb",
+		.pcie_power_gpio = "PE11",
+		.pcie_wake_gpio = "PE12",
+		.pcie_reset_gpio = "PE13",
+		.hw_id_level = 1,
+		.hw_id_lower_bound = 1519,
+		.hw_id_upper_bound = 1619, //1569mv +/- 50mv
+	},
+	{
+		.compatible = "allwinner,sun60i-a733",
+		.fdtfile = "allwinner/sun60i-a733-cubie-a7s.dtb",
+		.pcie_power_gpio = "PD20",
+		.pcie_wake_gpio = "PD21",
+		.pcie_reset_gpio = "PD22",
+		.hw_id_level = 1,
+		.hw_id_lower_bound = 1265,
+		.hw_id_upper_bound = 1365, //1315mv +/- 50mv
+	},
+};
+
+void radxa_set_board_type(void)
+{
+	int i, vol, level;
+
+	if (gpio_request(HW_ID_GPIO, "hw_id_level") != 0) {
+		debug("Failed to request GPIO %d for hardware ID detection\n", HW_ID_GPIO);
+		return;
+	}
+	gpio_direction_input(HW_ID_GPIO);
+	level = gpio_get_value(HW_ID_GPIO);
+	vol = sunxi_get_gpadc_vol(HW_ID_ADC_CHANNEL);
+	gpio_free(HW_ID_GPIO);
+
+	debug("%s vol=%d, level=%d\n", __func__, vol, level);
+	for (i = 0; i < countof(hw_info); i++) {
+		if (of_machine_is_compatible(hw_info[i].compatible) &&
+			vol >= hw_info[i].hw_id_lower_bound &&
+			vol <= hw_info[i].hw_id_upper_bound &&
+			level == hw_info[i].hw_id_level) {
+			board_index = i;
+			return;
+		}
+	}
+	printf("No compatible board type found for vol=%d, level=%d\n", vol, level);
+	return;
+}
+
+void radxa_set_compat_fdt(void)
+{
+	env_set("fdtfile", hw_info[board_index].fdtfile);
+	printf("Override default fdtfile to %s\n", hw_info[board_index].fdtfile);
+	return;
+}
+
+struct hw_info_def radxa_get_hw_info(void)
+{
+	return hw_info[board_index];
+}
diff --git a/src/board/sunxi/cubie_board.h b/src/board/sunxi/cubie_board.h
new file mode 100644
index 00000000000..95ec49e1a7a
--- /dev/null
+++ b/src/board/sunxi/cubie_board.h
@@ -0,0 +1,23 @@
+#include <asm-generic/gpio.h>
+#include <sunxi_gpadc.h>
+#include <dm/device.h>
+
+#define countof(x) (sizeof(x) / sizeof(x[0]))
+#define HW_ID_ADC_CHANNEL	2
+/*PK 24 */
+#define HW_ID_GPIO			344
+
+struct hw_info_def {
+	char *compatible;
+	char *fdtfile;
+	const char* pcie_power_gpio;
+	const char* pcie_wake_gpio;
+	const char* pcie_reset_gpio;
+	unsigned int hw_id_level;
+	unsigned int hw_id_lower_bound;
+	unsigned int hw_id_upper_bound;
+};
+
+void radxa_set_board_type(void);
+void radxa_set_compat_fdt(void);
+struct hw_info_def radxa_get_hw_info(void);
-- 
2.49.0

