+#ifndef __SUNXI_GPADC_H__
+#define __SUNXI_GPADC_H__
+
+int sunxi_get_gpadc_vol(int channel);
+int sunxi_gpadc_init(void);
+int sunxi_gpadc_read(int channel);
+
+#endif /*__SUNXI_GPADC_H__*/
